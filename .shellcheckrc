# dotrepos:begin .shellcheckrc@a21477f76706d320c4822194a116f8f2189a9251
# Sourced files not available at analysis time (CI, dynamic paths).
# SC1090 pairs with SC1091 — both fire when source paths are dynamic.
disable=SC1090
disable=SC1091

# SC2155 is intentionally NOT disabled.
# `local x=$(cmd)` masks return values from `set -e`.
# Fix by splitting: local x; x=$(cmd)
# dotrepos:end
