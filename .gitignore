# === Terraform & Terragrunt ===
**/.terraform/*
.terraform/
.terragrunt-cache/

# State files
*.tfstate
*.tfstate.*
tfstate.json
.terraform.tfstate.lock.info

# Plan files
*tfplan*

# Variable files (often sensitive)
*.tfvars
*.tfvars.json
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# CLI config
.terraformrc
terraform.rc

# Generated backend (root.hcl produces it via terragrunt)
backend.tf

# === SOPS / secrets ===
age.key
!*.sops

# === Local environment ===
.env
.envrc.local

# === Misc ===
.DS_Store
.backup
.archive
*.tf-ar
